{
  "framework": null,
  "buildCommand": "npm install",
  "installCommand": "npm install",
  "outputDirectory": ".",
  "functions": {
    "api/generate-video.js": {
      "maxDuration": 300
    },
    "api/save-approved.js": {
      "maxDuration": 120
    },
    "api/generate-static.js": {
      "maxDuration": 300
    },
    "api/compose-video.js": {
      "maxDuration": 300
    },
    "api/generate-roteiro.js": {
      "maxDuration": 120
    },
    "api/fix-roteiro.js": {
      "maxDuration": 120
    },
    "api/validate-roteiro.js": {
      "maxDuration": 120
    },
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/aprovados", "destination": "/aprovados.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
